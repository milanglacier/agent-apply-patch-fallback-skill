#!/usr/bin/env python3
"""
apply_patch - A Python implementation of the opencode patch tool.

Usage:
    apply_patch <patch_file>
    apply_patch <<'EOF'
    *** Begin Patch
    ...
    *** End Patch
    EOF
    cat patch.txt | apply_patch

Exit codes:
    0 - Success
    1 - Parse error
    2 - Application error (file not found, etc.)
    3 - I/O error
"""

import sys
import re
import argparse
from pathlib import Path
from typing import Dict, List, Optional, Tuple
from dataclasses import dataclass
from enum import Enum


class PatchError(Exception):
    """Base exception for patch errors."""

    pass


class ParseError(PatchError):
    """Patch format parsing error."""

    pass


class ApplicationError(PatchError):
    """Error applying patch to files."""

    pass


class HunkType(Enum):
    ADD = "add"
    DELETE = "delete"
    UPDATE = "update"


@dataclass
class UpdateChunk:
    """Represents an update chunk for a file."""

    old_lines: List[str]
    new_lines: List[str]
    change_context: Optional[str] = None
    is_end_of_file: bool = False


@dataclass
class Hunk:
    """Represents a single file operation in a patch."""

    type: HunkType
    path: str
    contents: str = ""  # For add operations
    move_path: Optional[str] = None  # For update with move
    chunks: List[UpdateChunk] = None  # For update operations


@dataclass
class FileChange:
    """Represents a file change result."""

    path: str
    type: str  # 'add', 'update', 'delete', 'move'
    move_path: Optional[str] = None


@dataclass
class FileSnapshot:
    """Stores the original filesystem state for rollback."""

    existed: bool
    contents: bytes = b""
    mode: Optional[int] = None
    is_dir: bool = False


def normalize_unicode(text: str) -> str:
    """Normalize Unicode punctuation to ASCII equivalents."""
    return (
        text.replace("\u2018", "'")
        .replace("\u2019", "'")
        .replace("\u201a", "'")
        .replace("\u201b", "'")
        .replace("\u201c", '"')
        .replace("\u201d", '"')
        .replace("\u201e", '"')
        .replace("\u201f", '"')
        .replace("\u2010", "-")
        .replace("\u2011", "-")
        .replace("\u2012", "-")
        .replace("\u2013", "-")
        .replace("\u2014", "-")
        .replace("\u2015", "-")
        .replace("\u2026", "...")
        .replace("\u00a0", " ")
    )


def seek_sequence(
    lines: List[str], pattern: List[str], start_idx: int, eof: bool = False
) -> int:
    """
    Find pattern in lines starting from start_idx.
    Tries multiple matching strategies: exact, rstrip, trim, normalized.
    Returns -1 if not found.
    """

    def try_match(compare_func) -> int:
        # If EOF anchor, try matching from end first
        if eof:
            from_end = len(lines) - len(pattern)
            if from_end >= start_idx:
                matches = True
                for j in range(len(pattern)):
                    if not compare_func(lines[from_end + j], pattern[j]):
                        matches = False
                        break
                if matches:
                    return from_end

        # Forward search
        for i in range(start_idx, len(lines) - len(pattern) + 1):
            matches = True
            for j in range(len(pattern)):
                if not compare_func(lines[i + j], pattern[j]):
                    matches = False
                    break
            if matches:
                return i
        return -1

    # Pass 1: exact match
    result = try_match(lambda a, b: a == b)
    if result != -1:
        return result

    # Pass 2: rstrip (trim trailing whitespace)
    result = try_match(lambda a, b: a.rstrip() == b.rstrip())
    if result != -1:
        return result

    # Pass 3: trim (both ends)
    result = try_match(lambda a, b: a.strip() == b.strip())
    if result != -1:
        return result

    # Pass 4: normalized (Unicode to ASCII)
    result = try_match(
        lambda a, b: normalize_unicode(a.strip()) == normalize_unicode(b.strip())
    )
    return result


def compute_replacements(
    original_lines: List[str], chunks: List[UpdateChunk], file_path: str
) -> List[Tuple[int, int, List[str]]]:
    """
    Compute replacements for update chunks.
    Returns list of (start_idx, old_len, new_lines).
    """
    replacements = []
    line_idx = 0

    for chunk in chunks:
        # Handle context-based seeking
        if chunk.change_context:
            context_idx = seek_sequence(
                original_lines, [chunk.change_context], line_idx
            )
            if context_idx == -1:
                raise ApplicationError(
                    f"Failed to find context '{chunk.change_context}' in {file_path}"
                )
            line_idx = context_idx + 1

        # Handle pure addition (no old lines)
        if len(chunk.old_lines) == 0:
            insertion_idx = line_idx
            replacements.append((insertion_idx, 0, chunk.new_lines))
            continue

        # Try to match old lines
        pattern = chunk.old_lines[:]
        new_slice = chunk.new_lines[:]
        found = seek_sequence(original_lines, pattern, line_idx, chunk.is_end_of_file)

        # Retry without trailing empty line if not found
        if found == -1 and pattern and pattern[-1] == "":
            pattern = pattern[:-1]
            if new_slice and new_slice[-1] == "":
                new_slice = new_slice[:-1]
            found = seek_sequence(
                original_lines, pattern, line_idx, chunk.is_end_of_file
            )

        if found != -1:
            replacements.append((found, len(pattern), new_slice))
            line_idx = found + len(pattern)
        else:
            raise ApplicationError(
                f"Failed to find expected lines in {file_path}:\n"
                + "\n".join(chunk.old_lines)
            )

    # Sort by index to apply in order
    replacements.sort(key=lambda x: x[0])
    return replacements


def apply_replacements(
    lines: List[str], replacements: List[Tuple[int, int, List[str]]]
) -> List[str]:
    """Apply replacements in reverse order to avoid index shifting."""
    result = lines[:]

    for start_idx, old_len, new_segment in reversed(replacements):
        # Remove old lines
        result = result[:start_idx] + result[start_idx + old_len :]

        # Insert new lines
        for j, line in enumerate(new_segment):
            result.insert(start_idx + j, line)

    return result


def derive_new_content_from_text(
    original_content: str, chunks: List[UpdateChunk], file_path: str
) -> str:
    """Derive updated file content from the provided text."""
    original_lines = original_content.split("\n")

    # Drop trailing empty element for consistent line counting
    if original_lines and original_lines[-1] == "":
        original_lines.pop()

    replacements = compute_replacements(original_lines, chunks, file_path)
    new_lines = apply_replacements(original_lines, replacements)

    # Ensure trailing newline
    if not new_lines or new_lines[-1] != "":
        new_lines.append("")

    return "\n".join(new_lines)


def derive_new_content(file_path: str, chunks: List[UpdateChunk]) -> str:
    """
    Derive new file content from update chunks.
    Returns the new content.
    """
    try:
        with open(file_path, "r", encoding="utf-8") as f:
            original_content = f.read()
    except FileNotFoundError:
        raise ApplicationError(f"File not found: {file_path}")
    except Exception as e:
        raise ApplicationError(f"Failed to read file {file_path}: {e}")

    return derive_new_content_from_text(original_content, chunks, file_path)


def parse_patch_header(
    lines: List[str], start_idx: int
) -> Optional[Tuple[str, Optional[str], int, HunkType]]:
    """
    Parse a patch header line.
    Returns (file_path, move_path, next_idx, hunk_type) or None.
    """
    line = lines[start_idx] if start_idx < len(lines) else ""

    if line.startswith("*** Add File:"):
        file_path = line[len("*** Add File:") :].strip()
        return (file_path, None, start_idx + 1, HunkType.ADD) if file_path else None

    if line.startswith("*** Delete File:"):
        file_path = line[len("*** Delete File:") :].strip()
        return (file_path, None, start_idx + 1, HunkType.DELETE) if file_path else None

    if line.startswith("*** Update File:"):
        file_path = line[len("*** Update File:") :].strip()
        move_path = None
        next_idx = start_idx + 1

        # Check for move directive
        if next_idx < len(lines) and lines[next_idx].startswith("*** Move to:"):
            move_path = lines[next_idx][len("*** Move to:") :].strip()
            next_idx += 1

        return (file_path, move_path, next_idx, HunkType.UPDATE) if file_path else None

    return None


def parse_add_file_content(lines: List[str], start_idx: int) -> Tuple[str, int]:
    """Parse content for Add File operation."""
    content_lines = []
    i = start_idx

    while i < len(lines) and not lines[i].startswith("***"):
        if lines[i].startswith("+"):
            content_lines.append(lines[i][1:])
        i += 1

    # Join with newlines but don't add trailing newline if last line was empty
    content = "\n".join(content_lines)
    return content, i


def parse_update_chunks(
    lines: List[str], start_idx: int
) -> Tuple[List[UpdateChunk], int]:
    """Parse update chunks for Update File operation."""
    chunks = []
    i = start_idx

    while i < len(lines) and not lines[i].startswith("***"):
        if lines[i].startswith("@@"):
            # Parse context line
            context_line = lines[i][2:].strip()
            i += 1

            old_lines = []
            new_lines = []
            is_end_of_file = False

            # Parse change lines
            while (
                i < len(lines)
                and not lines[i].startswith("@@")
                and (
                    not lines[i].startswith("***") or lines[i] == "*** End of File"
                )
            ):
                change_line = lines[i]

                if change_line == "*** End of File":
                    is_end_of_file = True
                    i += 1
                    continue

                if change_line.startswith(" "):
                    # Keep line - appears in both old and new
                    content = change_line[1:]
                    old_lines.append(content)
                    new_lines.append(content)
                elif change_line.startswith("-"):
                    # Remove line - only in old
                    old_lines.append(change_line[1:])
                elif change_line.startswith("+"):
                    # Add line - only in new
                    new_lines.append(change_line[1:])

                i += 1

            chunks.append(
                UpdateChunk(
                    old_lines=old_lines,
                    new_lines=new_lines,
                    change_context=context_line or None,
                    is_end_of_file=is_end_of_file,
                )
            )
        else:
            i += 1

    return chunks, i


def parse_patch(patch_text: str) -> List[Hunk]:
    """
    Parse patch text and return list of hunks.
    """
    # Strip heredoc markers if present
    heredoc_match = re.match(
        r'^(?:cat\s+)?<<[\'"]*(\w+)[\'"]*\s*\n([\s\S]*?)\n\1\s*$', patch_text.strip()
    )
    if heredoc_match:
        patch_text = heredoc_match.group(2)

    lines = patch_text.split("\n")
    hunks = []

    # Find Begin/End patch markers
    begin_marker = "*** Begin Patch"
    end_marker = "*** End Patch"

    begin_idx = -1
    end_idx = -1

    for i, line in enumerate(lines):
        if line.strip() == begin_marker:
            begin_idx = i
        elif line.strip() == end_marker:
            end_idx = i
            break

    if begin_idx == -1 or end_idx == -1:
        raise ParseError(
            f"Invalid patch format: missing {'Begin' if begin_idx == -1 else 'End'} marker"
        )

    if begin_idx >= end_idx:
        raise ParseError(
            "Invalid patch format: Begin marker must come before End marker"
        )

    # Parse content between markers
    i = begin_idx + 1

    while i < end_idx:
        header = parse_patch_header(lines, i)
        if not header:
            i += 1
            continue

        file_path, move_path, next_idx, hunk_type = header

        if lines[i].startswith("*** Add File:"):
            content, next_idx = parse_add_file_content(lines, next_idx)
            hunks.append(Hunk(type=HunkType.ADD, path=file_path, contents=content))
            i = next_idx

        elif lines[i].startswith("*** Delete File:"):
            hunks.append(Hunk(type=HunkType.DELETE, path=file_path))
            i = next_idx

        elif lines[i].startswith("*** Update File:"):
            chunks, next_idx = parse_update_chunks(lines, next_idx)
            hunks.append(
                Hunk(
                    type=HunkType.UPDATE,
                    path=file_path,
                    move_path=move_path,
                    chunks=chunks,
                )
            )
            i = next_idx
        else:
            i += 1

    return hunks


def snapshot_path(path: Path) -> FileSnapshot:
    """Capture the current state of a path before mutation."""
    if not path.exists():
        return FileSnapshot(existed=False)

    stat_result = path.stat()
    if path.is_dir():
        return FileSnapshot(existed=True, mode=stat_result.st_mode, is_dir=True)

    return FileSnapshot(
        existed=True,
        contents=path.read_bytes(),
        mode=stat_result.st_mode,
    )


def restore_snapshot(path: Path, snapshot: FileSnapshot) -> None:
    """Restore a path to its snapshotted state."""
    if not snapshot.existed:
        if path.exists() and not path.is_dir():
            path.unlink()
        return

    if snapshot.is_dir:
        path.mkdir(parents=True, exist_ok=True)
        if snapshot.mode is not None:
            path.chmod(snapshot.mode & 0o7777)
        return

    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_bytes(snapshot.contents)
    if snapshot.mode is not None:
        path.chmod(snapshot.mode & 0o7777)


def build_plan(
    hunks: List[Hunk], base_dir: str = "."
) -> List[Tuple[Hunk, Path, Optional[str]]]:
    """Validate hunks and precompute file contents before mutating the filesystem."""
    if not hunks:
        raise ApplicationError("No hunks to apply")

    planned_actions = []
    base = Path(base_dir).resolve()
    virtual_state: Dict[Path, Optional[str]] = {}

    def get_virtual_file(path: Path) -> Tuple[str, Optional[str]]:
        if path in virtual_state:
            content = virtual_state[path]
            if content is None:
                return "missing", None
            return "file", content

        if not path.exists():
            return "missing", None

        if path.is_dir():
            return "dir", None

        try:
            with open(path, "r", encoding="utf-8") as f:
                return "file", f.read()
        except Exception as e:
            raise ApplicationError(f"Failed to read file {path}: {e}")

    for hunk in hunks:
        file_path = base / hunk.path
        current_kind, current_content = get_virtual_file(file_path)

        if hunk.type == HunkType.ADD:
            if current_kind == "dir":
                raise ApplicationError(f"Path is a directory, not a file: {file_path}")
            planned_actions.append((hunk, file_path, hunk.contents))
            virtual_state[file_path] = hunk.contents
            continue

        if hunk.type == HunkType.DELETE:
            if current_kind == "missing":
                raise ApplicationError(f"File to delete not found: {file_path}")
            if current_kind == "dir":
                raise ApplicationError(f"Path is a directory, not a file: {file_path}")
            planned_actions.append((hunk, file_path, None))
            virtual_state[file_path] = None
            continue

        if current_kind == "missing":
            raise ApplicationError(f"File to update not found: {file_path}")

        if current_kind == "dir":
            raise ApplicationError(f"Path is a directory, not a file: {file_path}")

        new_content = derive_new_content_from_text(
            current_content or "", hunk.chunks, str(file_path)
        )
        planned_actions.append((hunk, file_path, new_content))

        if hunk.move_path:
            move_path = base / hunk.move_path
            move_kind, _ = get_virtual_file(move_path)
            if move_kind == "dir":
                raise ApplicationError(f"Path is a directory, not a file: {move_path}")
            virtual_state[file_path] = None
            virtual_state[move_path] = new_content
        else:
            virtual_state[file_path] = new_content

    return planned_actions


def apply_hunks(hunks: List[Hunk], base_dir: str = ".") -> List[FileChange]:
    """
    Apply hunks to the filesystem.
    Returns list of changes made.
    """
    planned_actions = build_plan(hunks, base_dir)
    changes = []
    base = Path(base_dir).resolve()
    snapshots: Dict[Path, FileSnapshot] = {}
    snapshot_order: List[Path] = []

    def remember(path: Path) -> None:
        if path not in snapshots:
            snapshots[path] = snapshot_path(path)
            snapshot_order.append(path)

    for hunk, file_path, _ in planned_actions:
        remember(file_path)
        if hunk.type == HunkType.UPDATE and hunk.move_path:
            remember(base / hunk.move_path)

    try:
        for hunk, file_path, new_content in planned_actions:
            if hunk.type == HunkType.ADD:
                file_path.parent.mkdir(parents=True, exist_ok=True)
                with open(file_path, "w", encoding="utf-8") as f:
                    f.write(new_content or "")
                changes.append(FileChange(path=str(file_path), type="add"))
                continue

            if hunk.type == HunkType.DELETE:
                file_path.unlink()
                changes.append(FileChange(path=str(file_path), type="delete"))
                continue

            if hunk.move_path:
                move_path = base / hunk.move_path
                move_path.parent.mkdir(parents=True, exist_ok=True)
                with open(move_path, "w", encoding="utf-8") as f:
                    f.write(new_content or "")
                file_path.unlink()
                changes.append(
                    FileChange(path=str(file_path), type="move", move_path=str(move_path))
                )
                continue

            with open(file_path, "w", encoding="utf-8") as f:
                f.write(new_content or "")
            changes.append(FileChange(path=str(file_path), type="update"))
    except ApplicationError:
        for path in reversed(snapshot_order):
            restore_snapshot(path, snapshots[path])
        raise
    except Exception as e:
        for path in reversed(snapshot_order):
            restore_snapshot(path, snapshots[path])
        raise ApplicationError(f"Failed to apply patch: {e}")

    return changes


def format_changes(changes: List[FileChange]) -> str:
    """Format changes for output."""
    lines = ["Success. Updated the following files:"]
    for change in changes:
        if change.type == "add":
            lines.append(f"A {change.path}")
        elif change.type == "delete":
            lines.append(f"D {change.path}")
        elif change.type == "move":
            lines.append(f"M {change.path} -> {change.move_path}")
        else:
            lines.append(f"M {change.path}")
    return "\n".join(lines)


def main():
    parser = argparse.ArgumentParser(
        description="Apply patch files to your codebase.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Patch format:
  *** Begin Patch
  *** Add File: <path>
  +<content lines>
  *** Update File: <path>
  *** Move to: <new_path>  (optional)
  @@ <context>
  -<old line>
  +<new line>
  *** Delete File: <path>
  *** End Patch

Examples:
  apply_patch patch.txt
  apply_patch <<'EOF'
  *** Begin Patch
  *** Add File: hello.txt
  +Hello World
  *** End Patch
  EOF
  cat patch.txt | apply_patch
        """,
    )
    parser.add_argument(
        "patch_file", nargs="?", help="Path to patch file (or stdin if not provided)"
    )
    parser.add_argument(
        "-d",
        "--directory",
        default=".",
        help="Base directory for file operations (default: current directory)",
    )
    parser.add_argument("-v", "--verbose", action="store_true", help="Verbose output")

    args = parser.parse_args()

    try:
        # Read patch content
        if args.patch_file:
            with open(args.patch_file, "r", encoding="utf-8") as f:
                patch_text = f.read()
        else:
            patch_text = sys.stdin.read()

        if not patch_text.strip():
            print("Error: No patch content provided", file=sys.stderr)
            sys.exit(1)

        # Parse patch
        try:
            hunks = parse_patch(patch_text)
        except ParseError as e:
            print(f"Parse error: {e}", file=sys.stderr)
            sys.exit(1)

        if not hunks:
            # Check for empty patch
            normalized = patch_text.replace("\r\n", "\n").replace("\r", "\n").strip()
            if normalized == "*** Begin Patch\n*** End Patch":
                print("Error: patch rejected: empty patch", file=sys.stderr)
                sys.exit(1)
            print("Error: No hunks found in patch", file=sys.stderr)
            sys.exit(1)

        if args.verbose:
            print(f"Parsed {len(hunks)} hunks", file=sys.stderr)

        # Apply hunks
        try:
            changes = apply_hunks(hunks, args.directory)
        except ApplicationError as e:
            print(f"Apply error: {e}", file=sys.stderr)
            sys.exit(2)

        # Output results
        print(format_changes(changes))
        sys.exit(0)

    except IOError as e:
        print(f"I/O error: {e}", file=sys.stderr)
        sys.exit(3)
    except KeyboardInterrupt:
        print("\nInterrupted", file=sys.stderr)
        sys.exit(130)


if __name__ == "__main__":
    main()
